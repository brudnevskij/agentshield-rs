# Private key used by the facilitator for settlement.
FACILITATOR_PRIVATE_KEY=0xreplace_me

# Local facilitator URL used later by AgentShield x402 middleware.
X402_FACILITATOR_URL=http://127.0.0.1:8080

# Wallet that receives x402 payments.
# Can be the same test wallet for demo, but cleaner to use separate receiver wallet.
X402_PAY_TO=0xreplace_me

# Base Sepolia
X402_NETWORK=eip155:84532
